# Base image for the HermesPy CI environment
# See https://github.com/pypa/manylinux for more information
FROM quay.io/pypa/manylinux_2_28_x86_64:latest

# Install external dependencies
RUN dnf -y install pandoc octave graphviz llvm-compat-libs
RUN dnf -y clean all

# Point drjit to the correct libLLVM
ENV DRJIT_LIBLLVM_PATH="/usr/lib64/llvm17/lib/libLLVM-17.so"

# Add python binary folder to PATH
ENV PATH="/opt/python/cp313-cp313/bin:${PATH}"

# Upgrade pip
RUN python -m pip install --no-cache-dir --upgrade pip

# Generate requirements file from HermesPy's current pyproject.toml
COPY pyproject.toml /tmp/pyproject.toml
RUN python -m pip install --no-cache-dir --upgrade pip-tools && pip-compile --all-extras --allow-unsafe -o /tmp/ci-requirements.txt /tmp/pyproject.toml

# Install all Python dependencies for HermesPy
RUN python -m pip install --no-cache-dir --upgrade -r /tmp/ci-requirements.txt